{
  "name": "flanterminal",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w @flanterminal/shared && concurrently --kill-others-on-fail --names shared,client,server \"npm run dev -w @flanterminal/shared\" \"npm run dev -w @flanterminal/client\" \"npm run dev -w @flanterminal/server\"",
    "build": "npm run build -w @flanterminal/shared && npm run build -w @flanterminal/client && npm run build -w @flanterminal/server && npm run verify:dist",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b packages/shared apps/client apps/server --pretty false",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "scripts/run-e2e.sh",
    "test:e2e:run": "playwright test",
    "verify:dist": "node scripts/verify-production-dist.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/express": "5.0.6",
    "@types/node": "24.10.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.4.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.0"
  }
}
