{
  "name": "@flanterminal/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "APP_PUBLIC_URL=${APP_PUBLIC_URL:-http://localhost:5173} tsx watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --config ../../vitest.config.ts --root . --passWithNoTests"
  },
  "dependencies": {
    "@flanterminal/shared": "*",
    "bcrypt": "^6.0.0",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "ipaddr.js": "2.4.0",
    "jose": "^6.2.3",
    "node-pty": "1.1.0",
    "pino": "10.3.1",
    "proxy-addr": "2.0.7",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/proxy-addr": "2.0.3",
    "tsx": "^4.23.0"
  }
}
