# Internal container port and canonical browser URL
APP_PORT=3000
# External host port used by Compose
HOST_PORT=3000
APP_BIND_HOST=0.0.0.0
APP_BASE_PATH=/
APP_PUBLIC_URL=http://localhost:3000
# Optional absolute path to a non-secret JSON configuration file
# APP_CONFIG_FILE=/app/config/flanterminal.json

# Persistent application data and terminal workspace limits
DATA_DIR=/app/data
HOME_DIR=/home/webterm
SESSION_MAX_COUNT=10
DEFAULT_SHELL=/bin/bash
ALLOWED_SHELLS=/bin/bash
DEFAULT_FONT_SIZE=14
MAX_FONT_SIZE=32
XTERM_SCROLLBACK=10000
MAX_XTERM_SCROLLBACK=100000
TMUX_HISTORY_LIMIT=20000
MAX_TMUX_HISTORY_LIMIT=1000000
MAX_STALE_SESSION_CLEANUP_HOURS=8760
SESSION_CLEANUP_INTERVAL_MINUTES=15

# Local authentication is the secure default. Put only the password-file path
# here; mount the password itself as a secret and never place it in this file.
AUTH_MODE=local
LOCAL_AUTH_USERNAME=webterm
LOCAL_AUTH_PASSWORD_FILE=/run/secrets/local_auth_password
BCRYPT_COST=12
AUTH_IDLE_MINUTES=60
AUTH_ABSOLUTE_HOURS=24
AUTH_SESSION_MAX_COUNT=32

# Cloudflare Access mode uses a validated JWT and does not need local
# credentials. Set AUTH_MODE=cloudflare-access, configure both values below,
# and omit the local password secret mount.
# CLOUDFLARE_TEAM_DOMAIN=https://example.cloudflareaccess.com
# CLOUDFLARE_ACCESS_AUD=replace_with_access_application_aud

# Generic trusted-header mode additionally requires an explicit trusted proxy.
# TRUST_PROXY accepts false, a hop count 1..8, or comma-separated IP/CIDR values.
TRUST_PROXY=false
TRUSTED_AUTH_HEADER=X-Auth-User

# WebSocket, reconnect, and logging controls
WS_HEARTBEAT_SECONDS=30
WS_MAX_BUFFER_BYTES=1048576
RESIZE_DEBOUNCE_MS=100
RECONNECT_MAX_SECONDS=15
LOG_LEVEL=info

# Runtime container identity
PUID=1000
PGID=1000
# Example timezone only; override for the deployment environment.
TZ=America/Denver
