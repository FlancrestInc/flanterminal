# Internal container port
APP_PORT=3000
# External host port
HOST_PORT=3000
APP_BIND_HOST=0.0.0.0
APP_BASE_PATH=/
APP_PUBLIC_URL=http://localhost:3000
DATA_DIR=/app/data
SESSION_MAX_COUNT=10

# Terminal defaults
DEFAULT_SHELL=/bin/bash
DEFAULT_FONT_SIZE=14
XTERM_SCROLLBACK=10000
TMUX_HISTORY_LIMIT=20000
WS_HEARTBEAT_SECONDS=30
WS_MAX_BUFFER_BYTES=1048576
RESIZE_DEBOUNCE_MS=100
RECONNECT_MAX_SECONDS=15

# Runtime identity and logging
LOG_LEVEL=info
PUID=1000
PGID=1000
# Example timezone; override for the deployment environment
TZ=America/Denver
